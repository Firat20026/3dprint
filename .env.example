# Database
DATABASE_URL=postgresql://frint3d:frint3d@localhost:5432/frint3d

# Redis (BullMQ)
REDIS_URL=redis://localhost:6379

# NextAuth
# Generate with: openssl rand -base64 32   (or)   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# CRITICAL: must be a strong random value in production. Rotating invalidates all active JWTs.
NEXTAUTH_SECRET=replace-with-strong-random-32-byte-base64
NEXTAUTH_URL=http://localhost:3000
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# iyzico
# Sandbox: https://sandbox-api.iyzipay.com  (key/secret prefix: "sandbox-...")
# Production: https://api.iyzipay.com
# Required buyer fields iyzico expects: gsmNumber (+90 format), identityNumber (TCKN — 11 digits),
# registrationAddress, city, country. Sandbox accepts identityNumber=11111111111.
IYZICO_API_KEY=sandbox-xxx
IYZICO_SECRET_KEY=sandbox-xxx
IYZICO_BASE_URL=https://sandbox-api.iyzipay.com

# Shopier (Developer REST API — ürün kataloğu)
# Katalog ve anasayfa "öne çıkanlar" Shopier ürünlerinden beslenir. Satın alma,
# ürünün Shopier sayfasında (product.url) tamamlanır.
# SHOPIER_API_TOKEN: PAT (Hesap Yönetimi → Kişisel Erişim Anahtarı, 2FA gerekir).
#   products:read scope'u şart. GET /v1/products 403 dönerse Shopier'den ürün
#   listeleme erişiminin açık olduğundan emin ol.
SHOPIER_API_TOKEN=
# Anasayfa "öne çıkanlar" için Shopier seçki (selection) ID. Boşsa en yeni ürünler.
SHOPIER_FEATURED_SELECTION_ID=
# Fixture/örnek ürün modu: auto (varsayılan) | on | off
#   auto → canlı veri yoksa SADECE dev'de örnek ürün gösterir (prod'da boş bırakır)
#   on   → her zaman örnek ürünler   off → sadece canlı (boşsa boş)
SHOPIER_FIXTURES=auto
# API ayarları (opsiyonel): base URL ve cache süresi (sn)
# SHOPIER_API_BASE=https://api.shopier.com/v1
# SHOPIER_REVALIDATE=60

# Meshy AI
# Provider:
#   "mock" (default) — bundled-sample STL, ~3s delay, no cost (dev-friendly)
#   "real"            — real Meshy API; requires MESHY_API_KEY
# Key format: starts with "msy_" — get from https://www.meshy.ai/settings/api
# Notes: real mode uses text-to-3d v2 (preview stage only — untextured mesh,
# fine for printing) and image-to-3d v1; polls every 8s up to 15 min.
MESHY_PROVIDER=mock
MESHY_API_KEY=

# Slicer
# Mode:
#   "mock"  — deterministic fake grams/seconds from STL size (dev, no binary)
#   "real"  — spawn OrcaSlicer CLI (requires ORCA_SLICER_BIN to exist)
#   unset   — auto: "real" if ORCA_SLICER_BIN points to an executable, else "mock"
# The worker Docker image installs OrcaSlicer and sets SLICER_MODE=real.
SLICER_MODE=mock
ORCA_SLICER_BIN=/usr/local/bin/orca-slicer
SLICER_PRINTER_PROFILE=./profiles/snapmaker_u1.json
# Max wall-clock per slice before the CLI is killed (ms). Default 5 min.
# SLICE_TIMEOUT_MS=300000
UPLOAD_DIR=./data/uploads
SLICE_DIR=./data/slices

# Bootstrap admin (created on first seed)
# IMPORTANT: change this to a strong password before first deploy. After first login,
# rotate again from /account/settings (or via reset-admin-password script).
ADMIN_BOOTSTRAP_EMAIL=admin@frint3d.local
ADMIN_BOOTSTRAP_PASSWORD=replace-with-strong-password

# Email (Resend) — optional. Leave empty to log emails to console instead of
# sending. Get a key at https://resend.com/api-keys. FROM must be a verified
# domain/sender, e.g. "frint3d <no-reply@yourdomain.com>".
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# Observability (optional — leave empty to use console+DB providers only)
# POSTHOG_KEY=
# POSTHOG_HOST=https://eu.i.posthog.com
# SENTRY_DSN=

# Internal renderer secret — shared between web and worker. Used by the
# worker's headless browser to authenticate against the thumbnail render
# page (/_render/design/[id]) and the save endpoint
# (/api/internal/thumbnail/[designId]). Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
INTERNAL_RENDERER_TOKEN=

# Internal base URL the worker uses to reach the web container. In Docker
# Compose this is the service name; locally use http://localhost:3000.
WEB_INTERNAL_URL=http://web:3000

# Chromium executable path inside the worker container. Set by the Dockerfile.
PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium
