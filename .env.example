# Database
DATABASE_URL=postgresql://frint3d:frint3d@localhost:5432/frint3d

# Redis (BullMQ)
REDIS_URL=redis://localhost:6379

# NextAuth
# Generate with: openssl rand -base64 32   (or)   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# CRITICAL: must be a strong random value in production. Rotating invalidates all active JWTs.
NEXTAUTH_SECRET=replace-with-strong-random-32-byte-base64
NEXTAUTH_URL=http://localhost:3000
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# iyzico
# Sandbox: https://sandbox-api.iyzipay.com  (key/secret prefix: "sandbox-...")
# Production: https://api.iyzipay.com
# Required buyer fields iyzico expects: gsmNumber (+90 format), identityNumber (TCKN — 11 digits),
# registrationAddress, city, country. Sandbox accepts identityNumber=11111111111.
IYZICO_API_KEY=sandbox-xxx
IYZICO_SECRET_KEY=sandbox-xxx
IYZICO_BASE_URL=https://sandbox-api.iyzipay.com

# Meshy AI
MESHY_PROVIDER=mock
MESHY_API_KEY=

# Slicer
ORCA_SLICER_BIN=/usr/local/bin/orca-slicer
SLICER_PRINTER_PROFILE=./profiles/snapmaker_u1.json
UPLOAD_DIR=./data/uploads
SLICE_DIR=./data/slices

# Bootstrap admin (created on first seed)
# IMPORTANT: change this to a strong password before first deploy. After first login,
# rotate again from /account/settings (or via reset-admin-password script).
ADMIN_BOOTSTRAP_EMAIL=admin@frint3d.local
ADMIN_BOOTSTRAP_PASSWORD=replace-with-strong-password

# Observability (optional — leave empty to use console+DB providers only)
# POSTHOG_KEY=
# POSTHOG_HOST=https://eu.i.posthog.com
# SENTRY_DSN=
